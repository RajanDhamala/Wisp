{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ESNext",
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "types": ["node"],
    "baseUrl": "."
  },
  "include": [
    "**/*.js",
    "**/*.mjs"
  ],
  "exclude": [
    "node_modules"
  ]
}
