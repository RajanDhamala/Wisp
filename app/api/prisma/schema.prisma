// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String          @id @default(uuid())
  fullname            String
  email               String          @unique
  avatar              String?
  memoryAutoEnabled   Boolean         @default(false)
  memoryAutoEnabledAt DateTime?
  session             Sessions[]
  projects            Project[]
  savedResponses      SavedResponse[]
  memories            UserMemory[]
  tokenQuota          TokenQuota?
  createdAt           DateTime        @default(now())
  provider            String
}

model Project {
  id        String     @id @default(uuid())
  name      String
  owner     String
  user      User       @relation(fields: [owner], references: [id], onDelete: Cascade)
  sessions  Sessions[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([owner, name])
  @@index([owner, updatedAt])
}

model Sessions {
  id          String              @id @default(uuid())
  title       String              @default("New chat")
  owner       String
  user        User                @relation(fields: [owner], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  messages    Messages[]
  memoryState SessionMemoryState?

  @@index([owner, updatedAt])
  @@index([projectId, updatedAt])
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model Messages {
  id                String      @id @default(uuid())
  role              MessageRole
  content           String      @db.Text
  model             String?
  inputTokens       Int         @default(0)
  outputTokens      Int         @default(0)
  cachedInputTokens Int         @default(0)
  totalTokens       Int         @default(0)
  createdAt         DateTime    @default(now())
  sessionId         String
  sessiondata       Sessions    @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model SavedResponse {
  id              String   @id @default(uuid())
  owner           String
  user            User     @relation(fields: [owner], references: [id], onDelete: Cascade)
  sourceMessageId String
  sourceSessionId String
  sourceChatTitle String
  content         String   @db.Text
  model           String?
  createdAt       DateTime @default(now())

  @@unique([owner, sourceMessageId])
  @@index([owner, createdAt])
}

model UserMemory {
  id              String   @id @default(uuid())
  owner           String
  user            User     @relation(fields: [owner], references: [id], onDelete: Cascade)
  memoryKey       String
  kind            String
  content         String   @db.Text
  confidence      Float
  importance      Float
  sourceSessionId String?
  sourceMessageId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([owner, memoryKey])
  @@index([owner, updatedAt])
}

model SessionMemoryState {
  sessionId          String    @id
  session            Sessions  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  processedThroughAt DateTime?
  processedMessageId String?
  updatedAt          DateTime  @updatedAt
}

model TokenQuota {
  owner           String   @id
  user            User     @relation(fields: [owner], references: [id], onDelete: Cascade)
  tokenLimit      BigInt
  remainingTokens BigInt
  periodStartedAt DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
